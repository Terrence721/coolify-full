includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - app/Actions
        - app/Console
        - app/Exceptions
        - app/Http
        - app/Jobs
        - app/Listeners
        - app/Models
        - app/Notifications
        - app/Policies
        - app/Providers
        - app/Traits

    ignoreErrors:
        -
            # Illuminate\Support\Collection's TValue generic is invariant, so a
            # Collection<string, non-empty-string> is never assignable to a
            # Collection<string, string> parameter even though every
            # non-empty-string trivially satisfies string. See
            # https://phpstan.org/blog/whats-up-with-template-covariant
            message: '#^Parameter \#1 \$variables of static method App\\Support\\Deployment\\RailpackConfigHelper::mergeDeployAptPackages\(\) expects Illuminate\\Support\\Collection<string, string>, Illuminate\\Support\\Collection<string, non\-empty\-string> given\.$#'
            identifier: argument.type
            count: 1
            path: app/Jobs/ApplicationDeploymentJob.php
